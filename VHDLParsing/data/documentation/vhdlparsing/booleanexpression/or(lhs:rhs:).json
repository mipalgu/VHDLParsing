mbol"},"doc://VHDLParsing/documentation/VHDLParsing/Expression":{"navigatorTitle":[{"text":"Expression","kind":"identifier"}],"title":"Expression","abstract":[{"text":"An ","type":"text"},{"code":"Expression","type":"codeVoice"},{"text":" represents a stand-alone statement that resolves to some value in ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":". Typical","type":"text"},{"text":" ","type":"text"},{"text":"expressions would include all operations after the ","type":"text"},{"code":"<=","type":"codeVoice"},{"text":" symbol in a ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":" assignment operation. Some","type":"text"},{"text":" ","type":"text"},{"text":"examples include arithmetic operations (+, -, \/, *), comparison operations (>, <, <=, >=, =, \/=), bitwise","type":"text"},{"text":" ","type":"text"},{"text":"operations (sll, srl, sla, sra, rol, ror), and may include references to pre-defined variables or literal","type":"text"},{"text":" ","type":"text"},{"text":"values. This type should not be used to describe branch statements such as ","type":"text"},{"code":"if","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"case","type":"codeVoice"},{"text":" statements, or","type":"text"},{"text":" ","type":"text"},{"text":"loops such as ","type":"text"},{"code":"for","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"while","type":"codeVoice"},{"text":" loops. For those types of expressions, use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/SynchronousBlock","type":"reference"},{"text":".","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Expression","kind":"identifier"}],"role":"symbol","url":"\/documentation\/vhdlparsing\/expression","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/Expression","type":"topic","kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/BooleanExpression":{"abstract":[{"type":"text","text":"A boolean expression containing common boolean operations. This type represents an expression that can be"},{"type":"text","text":" "},{"type":"text","text":"represented as a single logic expression. For example, "},{"type":"codeVoice","code":"a and b"},{"type":"text","text":" is a valid expression, but "},{"type":"codeVoice","code":"a and b or c"},{"type":"text","text":" "},{"type":"text","text":"is not since it contains two logic operations. On the contrary, "},{"type":"codeVoice","code":"a and (b or c)"},{"type":"text","text":" is a valid expression"},{"type":"text","text":" "},{"type":"text","text":"since the expression is represented as an "},{"type":"codeVoice","code":"and"},{"type":"text","text":" operation on two subexpressions (one of which is also a"},{"type":"text","text":" "},{"type":"text","text":"logical expression)."}],"role":"symbol","kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BooleanExpression","kind":"identifier"}],"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/BooleanExpression","url":"\/documentation\/vhdlparsing\/booleanexpression","type":"topic","title":"BooleanExpression","navigatorTitle":[{"text":"BooleanExpression","kind":"identifier"}]}}}