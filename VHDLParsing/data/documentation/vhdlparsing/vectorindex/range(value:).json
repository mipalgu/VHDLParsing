{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"A range of indexes in a vector.","type":"text"}],"variants":[{"paths":["\/documentation\/vhdlparsing\/vectorindex\/range(value:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex\/range(value:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/VHDLParsing\/documentation\/VHDLParsing","doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"range","kind":"identifier"},{"text":"(","kind":"text"},{"text":"value","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VectorSize","preciseIdentifier":"s:11VHDLParsing10VectorSizeO","kind":"typeIdentifier","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorSize"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["Linux"]}],"kind":"declarations"}],"metadata":{"title":"VectorIndex.range(value:)","modules":[{"name":"VHDLParsing"}],"externalID":"s:11VHDLParsing11VectorIndexO5rangeyAcA0B4SizeO_tcACmF","symbolKind":"case","roleHeading":"Case","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"range","kind":"identifier"},{"text":"(","kind":"text"},{"text":"value","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VectorSize","preciseIdentifier":"s:11VHDLParsing10VectorSizeO","kind":"typeIdentifier"},{"text":")","kind":"text"}],"role":"symbol"},"references":{"doc://VHDLParsing/documentation/VHDLParsing":{"title":"VHDLParsing","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing","type":"topic","url":"\/documentation\/vhdlparsing","role":"collection","abstract":[],"kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/VectorIndex":{"role":"symbol","title":"VectorIndex","kind":"symbol","navigatorTitle":[{"text":"VectorIndex","kind":"identifier"}],"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VectorIndex","kind":"identifier"}],"url":"\/documentation\/vhdlparsing\/vectorindex","abstract":[{"type":"text","text":"An index of a vector in "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":". This type is designed to represent indexes in an assignment statement for"},{"type":"text","text":" "},{"type":"text","text":"a vector type. For example, you may have a signal "},{"code":"x","type":"codeVoice"},{"type":"text","text":" of type "},{"code":"std_logic_vector(7 downto 0)","type":"codeVoice"},{"type":"text","text":" that you"},{"type":"text","text":" "},{"type":"text","text":"want to assign a value to. In "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":", you can do this with the statement "},{"code":"x <= (others => '0');","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This type is designed to represent the "},{"code":"others","type":"codeVoice"},{"type":"text","text":" in that statement and other supported values like it, such"},{"type":"text","text":" "},{"type":"text","text":"as those found in "},{"type":"codeVoice","code":"x <= (7 => '1', others => '0');"},{"text":". This statement would produce two instances of this","type":"text"},{"text":" ","type":"text"},{"text":"type for the values ","type":"text"},{"type":"codeVoice","code":"7"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"others"},{"text":". This type also supports ","type":"text"},{"type":"codeVoice","code":"VHDL2008"},{"text":" statements that support a range","type":"text"},{"text":" ","type":"text"},{"text":"of values, e.g. ","type":"text"},{"type":"codeVoice","code":"x <= (7 downto 0 => '1');"},{"text":".","type":"text"}]},"doc://VHDLParsing/documentation/VHDLParsing/VectorSize":{"navigatorTitle":[{"kind":"identifier","text":"VectorSize"}],"title":"VectorSize","abstract":[{"text":"A type for representing VHDL vector sizes. This type is equivalent to the ","type":"text"},{"type":"codeVoice","code":"range"},{"text":" of a VHDL vector type,","type":"text"},{"text":" ","type":"text"},{"text":"e.g. ","type":"text"},{"inlineContent":[{"text":"5 downto 3","type":"text"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"3 to 5"}],"type":"emphasis"},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"VectorSize"}],"role":"symbol","url":"\/documentation\/vhdlparsing\/vectorsize","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorSize","type":"topic","kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/VectorIndex/range(value:)":{"type":"topic","title":"VectorIndex.range(value:)","abstract":[{"text":"A range of indexes in a vector.","type":"text"}],"fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"range"},{"kind":"text","text":"("},{"kind":"externalParam","text":"value"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"VectorSize","preciseIdentifier":"s:11VHDLParsing10VectorSizeO"},{"kind":"text","text":")"}],"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex\/range(value:)","url":"\/documentation\/vhdlparsing\/vectorindex\/range(value:)","kind":"symbol","role":"symbol"}}}