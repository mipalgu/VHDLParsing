{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"symbolKind":"init","externalID":"s:11VHDLParsing11VectorIndexO8rawValueACSgSS_tcfc","title":"init(rawValue:)","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"?(","kind":"text"},{"text":"rawValue","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":")","kind":"text"}],"roleHeading":"Initializer","modules":[{"name":"VHDLParsing"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/VHDLParsing\/documentation\/VHDLParsing","doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex"]]},"variants":[{"paths":["\/documentation\/vhdlparsing\/vectorindex\/init(rawvalue:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex\/init(rawValue:)","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["Linux"],"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"text":"?(","kind":"text"},{"text":"rawValue","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":")","kind":"text"}]}]},{"parameters":[{"name":"rawValue","content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"VHDL"},{"type":"text","text":" code representing the index. This code should only contain the index"},{"type":"text","text":" "},{"type":"text","text":"itself and no other statements or parantheses."}],"type":"paragraph"}]}],"kind":"parameters"}],"abstract":[{"type":"text","text":"Creates a new "},{"code":"VectorIndex","type":"codeVoice"},{"type":"text","text":" from the "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":" code representing it."}],"references":{"doc://VHDLParsing/documentation/VHDLParsing/VectorIndex/init(rawValue:)":{"role":"symbol","title":"init(rawValue:)","kind":"symbol","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex\/init(rawValue:)","type":"topic","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"?("},{"kind":"externalParam","text":"rawValue"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":")"}],"url":"\/documentation\/vhdlparsing\/vectorindex\/init(rawvalue:)","abstract":[{"text":"Creates a new ","type":"text"},{"code":"VectorIndex","type":"codeVoice"},{"text":" from the ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":" code representing it.","type":"text"}]},"doc://VHDLParsing/documentation/VHDLParsing":{"title":"VHDLParsing","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing","type":"topic","url":"\/documentation\/vhdlparsing","role":"collection","abstract":[],"kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/VectorIndex":{"role":"symbol","title":"VectorIndex","kind":"symbol","navigatorTitle":[{"text":"VectorIndex","kind":"identifier"}],"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VectorIndex","kind":"identifier"}],"url":"\/documentation\/vhdlparsing\/vectorindex","abstract":[{"type":"text","text":"An index of a vector in "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":". This type is designed to represent indexes in an assignment statement for"},{"type":"text","text":" "},{"type":"text","text":"a vector type. For example, you may have a signal "},{"code":"x","type":"codeVoice"},{"type":"text","text":" of type "},{"code":"std_logic_vector(7 downto 0)","type":"codeVoice"},{"type":"text","text":" that you"},{"type":"text","text":" "},{"type":"text","text":"want to assign a value to. In "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":", you can do this with the statement "},{"code":"x <= (others => '0');","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This type is designed to represent the "},{"code":"others","type":"codeVoice"},{"type":"text","text":" in that statement and other supported values like it, such"},{"type":"text","text":" "},{"type":"text","text":"as those found in "},{"type":"codeVoice","code":"x <= (7 => '1', others => '0');"},{"text":". This statement would produce two instances of this","type":"text"},{"text":" ","type":"text"},{"text":"type for the values ","type":"text"},{"type":"codeVoice","code":"7"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"others"},{"text":". This type also supports ","type":"text"},{"type":"codeVoice","code":"VHDL2008"},{"text":" statements that support a range","type":"text"},{"text":" ","type":"text"},{"text":"of values, e.g. ","type":"text"},{"type":"codeVoice","code":"x <= (7 downto 0 => '1');"},{"text":".","type":"text"}]}}}