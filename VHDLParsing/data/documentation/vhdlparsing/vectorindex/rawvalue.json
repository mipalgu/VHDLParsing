,{"text":"VectorIndex","kind":"identifier"}],"url":"\/documentation\/vhdlparsing\/vectorindex","abstract":[{"type":"text","text":"An index of a vector in "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":". This type is designed to represent indexes in an assignment statement for"},{"type":"text","text":" "},{"type":"text","text":"a vector type. For example, you may have a signal "},{"code":"x","type":"codeVoice"},{"type":"text","text":" of type "},{"code":"std_logic_vector(7 downto 0)","type":"codeVoice"},{"type":"text","text":" that you"},{"type":"text","text":" "},{"type":"text","text":"want to assign a value to. In "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":", you can do this with the statement "},{"code":"x <= (others => '0');","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This type is designed to represent the "},{"code":"others","type":"codeVoice"},{"type":"text","text":" in that statement and other supported values like it, such"},{"type":"text","text":" "},{"type":"text","text":"as those found in "},{"type":"codeVoice","code":"x <= (7 => '1', others => '0');"},{"text":". This statement would produce two instances of this","type":"text"},{"text":" ","type":"text"},{"text":"type for the values ","type":"text"},{"type":"codeVoice","code":"7"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"others"},{"text":". This type also supports ","type":"text"},{"type":"codeVoice","code":"VHDL2008"},{"text":" statements that support a range","type":"text"},{"text":" ","type":"text"},{"text":"of values, e.g. ","type":"text"},{"type":"codeVoice","code":"x <= (7 downto 0 => '1');"},{"text":".","type":"text"}]},"doc://VHDLParsing/documentation/VHDLParsing/VectorIndex/rawValue":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"rawValue","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}],"url":"\/documentation\/vhdlparsing\/vectorindex\/rawvalue","role":"symbol","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex\/rawValue","abstract":[{"type":"text","text":"The "},{"code":"VHDL","type":"codeVoice"},{"text":" code representing this index.","type":"text"}],"kind":"symbol","type":"topic","title":"rawValue"}}}