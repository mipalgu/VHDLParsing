cumentation\/vhdlparsing\/vectorindex","abstract":[{"type":"text","text":"An index of a vector in "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":". This type is designed to represent indexes in an assignment statement for"},{"type":"text","text":" "},{"type":"text","text":"a vector type. For example, you may have a signal "},{"code":"x","type":"codeVoice"},{"type":"text","text":" of type "},{"code":"std_logic_vector(7 downto 0)","type":"codeVoice"},{"type":"text","text":" that you"},{"type":"text","text":" "},{"type":"text","text":"want to assign a value to. In "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":", you can do this with the statement "},{"code":"x <= (others => '0');","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This type is designed to represent the "},{"code":"others","type":"codeVoice"},{"type":"text","text":" in that statement and other supported values like it, such"},{"type":"text","text":" "},{"type":"text","text":"as those found in "},{"type":"codeVoice","code":"x <= (7 => '1', others => '0');"},{"text":". This statement would produce two instances of this","type":"text"},{"text":" ","type":"text"},{"text":"type for the values ","type":"text"},{"type":"codeVoice","code":"7"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"others"},{"text":". This type also supports ","type":"text"},{"type":"codeVoice","code":"VHDL2008"},{"text":" statements that support a range","type":"text"},{"text":" ","type":"text"},{"text":"of values, e.g. ","type":"text"},{"type":"codeVoice","code":"x <= (7 downto 0 => '1');"},{"text":".","type":"text"}]},"doc://VHDLParsing/documentation/VHDLParsing/Expression":{"navigatorTitle":[{"text":"Expression","kind":"identifier"}],"title":"Expression","abstract":[{"text":"An ","type":"text"},{"code":"Expression","type":"codeVoice"},{"text":" represents a stand-alone statement that resolves to some value in ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":". Typical","type":"text"},{"text":" ","type":"text"},{"text":"expressions would include all operations after the ","type":"text"},{"code":"<=","type":"codeVoice"},{"text":" symbol in a ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":" assignment operation. Some","type":"text"},{"text":" ","type":"text"},{"text":"examples include arithmetic operations (+, -, \/, *), comparison operations (>, <, <=, >=, =, \/=), bitwise","type":"text"},{"text":" ","type":"text"},{"text":"operations (sll, srl, sla, sra, rol, ror), and may include references to pre-defined variables or literal","type":"text"},{"text":" ","type":"text"},{"text":"values. This type should not be used to describe branch statements such as ","type":"text"},{"code":"if","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"case","type":"codeVoice"},{"text":" statements, or","type":"text"},{"text":" ","type":"text"},{"text":"loops such as ","type":"text"},{"code":"for","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"while","type":"codeVoice"},{"text":" loops. For those types of expressions, use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/SynchronousBlock","type":"reference"},{"text":".","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Expression","kind":"identifier"}],"role":"symbol","url":"\/documentation\/vhdlparsing\/expression","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/Expression","type":"topic","kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing":{"title":"VHDLParsing","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing","type":"topic","url":"\/documentation\/vhdlparsing","role":"collection","abstract":[],"kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/SynchronousBlock":{"navigatorTitle":[{"text":"SynchronousBlock","kind":"identifier"}],"title":"SynchronousBlock","abstract":[{"text":"A type for representing code that exists within a ","type":"text"},{"code":"process","type":"codeVoice"},{"text":" block in ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":".","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SynchronousBlock","kind":"identifier"}],"role":"symbol","url":"\/documentation\/vhdlparsing\/synchronousblock","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/SynchronousBlock","type":"topic","kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/VectorIndex/index(value:)":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"index","kind":"identifier"},{"text":"(","kind":"text"},{"text":"value","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:11VHDLParsing10ExpressionO","text":"Expression","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"\/documentation\/vhdlparsing\/vectorindex\/index(value:)","title":"VectorIndex.index(value:)","type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex\/index(value:)","abstract":[{"type":"text","text":"An index in a vector."}]}}}