ants":[{"paths":["\/documentation\/vhdlparsing\/variablereference\/indexed(name:index:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://VHDLParsing/documentation/VHDLParsing/VariableReference":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariableReference","kind":"identifier"}],"type":"topic","role":"symbol","abstract":[{"type":"text","text":"A type for defining types of references to a variable."}],"navigatorTitle":[{"text":"VariableReference","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VariableReference","url":"\/documentation\/vhdlparsing\/variablereference","title":"VariableReference"},"doc://VHDLParsing/documentation/VHDLParsing":{"title":"VHDLParsing","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing","type":"topic","url":"\/documentation\/vhdlparsing","role":"collection","abstract":[],"kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/VariableName":{"url":"\/documentation\/vhdlparsing\/variablename","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VariableName","type":"topic","title":"VariableName","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariableName","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"VariableName","kind":"identifier"}],"abstract":[{"text":"Valid VHDL variable names. This struct represents a valid VHDL variable name. It is impossible to create","type":"text"},{"text":" ","type":"text"},{"text":"an invalid name using the public interface of this struct.","type":"text"}],"role":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/VariableReference/indexed(name:index:)":{"title":"VariableReference.indexed(name:index:)","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"indexed"},{"kind":"text","text":"("},{"kind":"externalParam","text":"name"},{"kind":"text","text":": "},{"preciseIdentifier":"s:11VHDLParsing12VariableNameV","kind":"typeIdentifier","text":"VariableName"},{"kind":"text","text":", "},{"kind":"externalParam","text":"index"},{"kind":"text","text":": "},{"preciseIdentifier":"s:11VHDLParsing11VectorIndexO","kind":"typeIdentifier","text":"VectorIndex"},{"kind":"text","text":")"}],"url":"\/documentation\/vhdlparsing\/variablereference\/indexed(name:index:)","kind":"symbol","abstract":[{"type":"text","text":"Indexing a variable."}],"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VariableReference\/indexed(name:index:)"},"doc://VHDLParsing/documentation/VHDLParsing/VectorIndex":{"role":"symbol","title":"VectorIndex","kind":"symbol","navigatorTitle":[{"text":"VectorIndex","kind":"identifier"}],"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VectorIndex","kind":"identifier"}],"url":"\/documentation\/vhdlparsing\/vectorindex","abstract":[{"type":"text","text":"An index of a vector in "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":". This type is designed to represent indexes in an assignment statement for"},{"type":"text","text":" "},{"type":"text","text":"a vector type. For example, you may have a signal "},{"code":"x","type":"codeVoice"},{"type":"text","text":" of type "},{"code":"std_logic_vector(7 downto 0)","type":"codeVoice"},{"type":"text","text":" that you"},{"type":"text","text":" "},{"type":"text","text":"want to assign a value to. In "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":", you can do this with the statement "},{"code":"x <= (others => '0');","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This type is designed to represent the "},{"code":"others","type":"codeVoice"},{"type":"text","text":" in that statement and other supported values like it, such"},{"type":"text","text":" "},{"type":"text","text":"as those found in "},{"type":"codeVoice","code":"x <= (7 => '1', others => '0');"},{"text":". This statement would produce two instances of this","type":"text"},{"text":" ","type":"text"},{"text":"type for the values ","type":"text"},{"type":"codeVoice","code":"7"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"others"},{"text":". This type also supports ","type":"text"},{"type":"codeVoice","code":"VHDL2008"},{"text":" statements that support a range","type":"text"},{"text":" ","type":"text"},{"text":"of values, e.g. ","type":"text"},{"type":"codeVoice","code":"x <= (7 downto 0 => '1');"},{"text":".","type":"text"}]}}}