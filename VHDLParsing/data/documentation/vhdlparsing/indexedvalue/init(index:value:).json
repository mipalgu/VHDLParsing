{"kind":"symbol","sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/vhdlparsing\/indexedvalue\/init(index:value:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"platforms":["Linux"],"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"index"},{"kind":"text","text":": "},{"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex","preciseIdentifier":"s:11VHDLParsing11VectorIndexO","kind":"typeIdentifier","text":"VectorIndex"},{"kind":"text","text":", "},{"kind":"externalParam","text":"value"},{"kind":"text","text":": "},{"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/SignalLiteral","preciseIdentifier":"s:11VHDLParsing13SignalLiteralO","kind":"typeIdentifier","text":"SignalLiteral"},{"kind":"text","text":")"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The index within a vector type to assign the ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" to.","type":"text"}]}],"name":"index"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The value to assign to the bit located at "},{"type":"codeVoice","code":"index"},{"type":"text","text":"."}]}],"name":"value"}]}],"metadata":{"title":"init(index:value:)","externalID":"s:11VHDLParsing12IndexedValueV5index5valueAcA11VectorIndexO_AA13SignalLiteralOtcfc","modules":[{"name":"VHDLParsing"}],"symbolKind":"init","roleHeading":"Initializer","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"index","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VectorIndex","preciseIdentifier":"s:11VHDLParsing11VectorIndexO","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"value","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SignalLiteral","kind":"typeIdentifier","preciseIdentifier":"s:11VHDLParsing13SignalLiteralO"},{"text":")","kind":"text"}],"role":"symbol"},"abstract":[{"text":"Intialise an indexed value with an index and value.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/VHDLParsing\/documentation\/VHDLParsing","doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/IndexedValue"]]},"identifier":{"url":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/IndexedValue\/init(index:value:)","interfaceLanguage":"swift"},"references":{"doc://VHDLParsing/documentation/VHDLParsing/IndexedValue":{"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/IndexedValue","abstract":[{"text":"This type represents a value for a specific index in a vector type within ","type":"text"},{"type":"codeVoice","code":"VHDL"},{"text":". For example, consider a","type":"text"},{"text":" ","type":"text"},{"text":"signal ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" with type ","type":"text"},{"code":"std_logic_vector(3 downto 0)","type":"codeVoice"},{"text":". We can assign specific bits within ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" by using the","type":"text"},{"text":" ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":" statement ","type":"text"},{"code":"x <= (3 => '1', others => '0');","type":"codeVoice"},{"text":". This statement says bit 3 of ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" should be set to 1","type":"text"},{"text":" ","type":"text"},{"text":"and all other bits to be set to 0. This type can be used to represent both expressions ","type":"text"},{"code":"3 => '1'","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"others => '0'","type":"codeVoice"},{"text":" as two separate instances of this type.","type":"text"}],"kind":"symbol","title":"IndexedValue","role":"symbol","navigatorTitle":[{"text":"IndexedValue","kind":"identifier"}],"url":"\/documentation\/vhdlparsing\/indexedvalue","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IndexedValue","kind":"identifier"}]},"doc://VHDLParsing/documentation/VHDLParsing":{"title":"VHDLParsing","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing","type":"topic","url":"\/documentation\/vhdlparsing","role":"collection","abstract":[],"kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/VectorIndex":{"role":"symbol","title":"VectorIndex","kind":"symbol","navigatorTitle":[{"text":"VectorIndex","kind":"identifier"}],"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/VectorIndex","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VectorIndex","kind":"identifier"}],"url":"\/documentation\/vhdlparsing\/vectorindex","abstract":[{"type":"text","text":"An index of a vector in "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":". This type is designed to represent indexes in an assignment statement for"},{"type":"text","text":" "},{"type":"text","text":"a vector type. For example, you may have a signal "},{"code":"x","type":"codeVoice"},{"type":"text","text":" of type "},{"code":"std_logic_vector(7 downto 0)","type":"codeVoice"},{"type":"text","text":" that you"},{"type":"text","text":" "},{"type":"text","text":"want to assign a value to. In "},{"code":"VHDL","type":"codeVoice"},{"type":"text","text":", you can do this with the statement "},{"code":"x <= (others => '0');","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This type is designed to represent the "},{"code":"others","type":"codeVoice"},{"type":"text","text":" in that statement and other supported values like it, such"},{"type":"text","text":" "},{"type":"text","text":"as those found in "},{"type":"codeVoice","code":"x <= (7 => '1', others => '0');"},{"text":". This statement would produce two instances of this","type":"text"},{"text":" ","type":"text"},{"text":"type for the values ","type":"text"},{"type":"codeVoice","code":"7"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"others"},{"text":". This type also supports ","type":"text"},{"type":"codeVoice","code":"VHDL2008"},{"text":" statements that support a range","type":"text"},{"text":" ","type":"text"},{"text":"of values, e.g. ","type":"text"},{"type":"codeVoice","code":"x <= (7 downto 0 => '1');"},{"text":".","type":"text"}]},"doc://VHDLParsing/documentation/VHDLParsing/IndexedValue/init(index:value:)":{"url":"\/documentation\/vhdlparsing\/indexedvalue\/init(index:value:)","role":"symbol","type":"topic","title":"init(index:value:)","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/IndexedValue\/init(index:value:)","abstract":[{"text":"Intialise an indexed value with an index and value.","type":"text"}],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"index","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:11VHDLParsing11VectorIndexO","text":"VectorIndex","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"value","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:11VHDLParsing13SignalLiteralO","text":"SignalLiteral","kind":"typeIdentifier"},{"text":")","kind":"text"}],"kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/SignalLiteral":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SignalLiteral"}],"title":"SignalLiteral","abstract":[{"type":"text","text":"A type for representing all signal literals."}],"url":"\/documentation\/vhdlparsing\/signalliteral","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/SignalLiteral","navigatorTitle":[{"kind":"identifier","text":"SignalLiteral"}]}}}