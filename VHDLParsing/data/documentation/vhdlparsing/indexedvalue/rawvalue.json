type":"text"},{"code":"x","type":"codeVoice"},{"text":" by using the","type":"text"},{"text":" ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":" statement ","type":"text"},{"code":"x <= (3 => '1', others => '0');","type":"codeVoice"},{"text":". This statement says bit 3 of ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" should be set to 1","type":"text"},{"text":" ","type":"text"},{"text":"and all other bits to be set to 0. This type can be used to represent both expressions ","type":"text"},{"code":"3 => '1'","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"others => '0'","type":"codeVoice"},{"text":" as two separate instances of this type.","type":"text"}],"kind":"symbol","title":"IndexedValue","role":"symbol","navigatorTitle":[{"text":"IndexedValue","kind":"identifier"}],"url":"\/documentation\/vhdlparsing\/indexedvalue","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IndexedValue","kind":"identifier"}]},"doc://VHDLParsing/documentation/VHDLParsing/IndexedValue/rawValue":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"rawValue"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}],"kind":"symbol","url":"\/documentation\/vhdlparsing\/indexedvalue\/rawvalue","title":"rawValue","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/IndexedValue\/rawValue","role":"symbol","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"VHDL"},{"text":" representation of this type.","type":"text"}]},"doc://VHDLParsing/documentation/VHDLParsing":{"title":"VHDLParsing","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing","type":"topic","url":"\/documentation\/vhdlparsing","role":"collection","abstract":[],"kind":"symbol"}}}