 consider a","type":"text"},{"text":" ","type":"text"},{"text":"signal ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" with type ","type":"text"},{"code":"std_logic_vector(3 downto 0)","type":"codeVoice"},{"text":". We can assign specific bits within ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" by using the","type":"text"},{"text":" ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":" statement ","type":"text"},{"code":"x <= (3 => '1', others => '0');","type":"codeVoice"},{"text":". This statement says bit 3 of ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" should be set to 1","type":"text"},{"text":" ","type":"text"},{"text":"and all other bits to be set to 0. This type can be used to represent both expressions ","type":"text"},{"code":"3 => '1'","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"others => '0'","type":"codeVoice"},{"text":" as two separate instances of this type.","type":"text"}],"kind":"symbol","title":"IndexedValue","role":"symbol","navigatorTitle":[{"text":"IndexedValue","kind":"identifier"}],"url":"\/documentation\/vhdlparsing\/indexedvalue","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IndexedValue","kind":"identifier"}]},"doc://VHDLParsing/documentation/VHDLParsing/IndexedVector/init(values:)":{"title":"init(values:)","url":"\/documentation\/vhdlparsing\/indexedvector\/init(values:)","kind":"symbol","abstract":[{"type":"text","text":"Initialise an instance of this type with the index values."}],"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/IndexedVector\/init(values:)","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"values"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","preciseIdentifier":"s:11VHDLParsing12IndexedValueV","text":"IndexedValue"},{"kind":"text","text":"])"}]},"doc://VHDLParsing/docu