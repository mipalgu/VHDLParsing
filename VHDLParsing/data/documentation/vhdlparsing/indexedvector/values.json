text":". We can assign specific bits within ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" by using the","type":"text"},{"text":" ","type":"text"},{"code":"VHDL","type":"codeVoice"},{"text":" statement ","type":"text"},{"code":"x <= (3 => '1', others => '0');","type":"codeVoice"},{"text":". This statement says bit 3 of ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" should be set to 1","type":"text"},{"text":" ","type":"text"},{"text":"and all other bits to be set to 0. This type can be used to represent both expressions ","type":"text"},{"code":"3 => '1'","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"others => '0'","type":"codeVoice"},{"text":" as two separate instances of this type.","type":"text"}],"kind":"symbol","title":"IndexedValue","role":"symbol","navigatorTitle":[{"text":"IndexedValue","kind":"identifier"}],"url":"\/documentation\/vhdlparsing\/indexedvalue","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IndexedValue","kind":"identifier"}]},"doc://VHDLParsing/documentation/VHDLParsing/IndexedVector/values":{"type":"topic","kind":"symbol","role":"symbol","title":"values","url":"\/documentation\/vhdlparsing\/indexedvector\/values","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"values"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","text":"IndexedValue","preciseIdentifier":"s:11VHDLParsing12IndexedValueV"},{"kind":"text","text":"]"}],"identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/IndexedVector\/values","abstract":[{"type":"text","text":"The values for each index."}]},"doc://VHDLParsing/documentation/VHDLParsing":{"title":"VHDLParsing","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing","type":"topic","url":"\/documentation\/vhdlparsing","role":"collection","abstract":[],"kind":"symbol"},"doc://VHDLParsing/documentation/VHDLParsing/IndexedVector":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IndexedVector","kind":"identifier"}],"abstract":[{"text":"A type for representing vector literals that assign specific bit\/logic values to specific indices.","type":"text"},{"text":" ","type":"text"},{"text":"This struct is used to represent ","type":"text"},{"type":"codeVoice","code":"VHDL"},{"text":" expressions of the form ","type":"text"},{"type":"codeVoice","code":"(0 => '0', 1 => '1', 2 => '0')"},{"text":", etc.","type":"text"},{"text":" ","type":"text"},{"text":"For example, consider a signal ","type":"text"},{"type":"codeVoice","code":"x"},{"text":" that is a ","type":"text"},{"type":"codeVoice","code":"std_logic_vector(7 downto 0)"},{"text":". We may assign values to ","type":"text"},{"type":"codeVoice","code":"x"},{"text":" ","type":"text"},{"text":"by using the ","type":"text"},{"type":"codeVoice","code":"VHDL"},{"text":" expression ","type":"text"},{"type":"codeVoice","code":"x <= (7 => '1', 6 downto 3 => '0', others => '1')"},{"text":". We can use an instance","type":"text"},{"text":" ","type":"text"},{"text":"of this type to parse and generate the expression after the ","type":"text"},{"type":"codeVoice","code":"<="},{"text":" symbol.","type":"text"}],"url":"\/documentation\/vhdlparsing\/indexedvector","type":"topic","navigatorTitle":[{"text":"IndexedVector","kind":"identifier"}],"kind":"symbol","title":"IndexedVector","identifier":"doc:\/\/VHDLParsing\/documentation\/VHDLParsing\/IndexedVector"}}}